# Required: Enoki private API key from Enoki portal
ENOKI_PRIVATE_KEY=your_enoki_private_key_here

# Required: your deployed package containing `content_creator` module
PACKAGE_ID=0xYOUR_CONTENT_CREATOR_PACKAGE_ID

# Optional
PORT=3001
SUI_NETWORK=testnet
FRONTEND_URL=http://localhost:5173
ENOKI_SUBNAME_DOMAIN=your-domain.sui
