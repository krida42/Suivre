# Enoki Configuration - Get Private Key from Enoki Portal (https://enoki.mystenlabs.com)
ENOKI_PRIVATE_KEY=your_enoki_private_key_here

# Server Configuration
PORT=3001

# Walrus token-gating configuration (optional but required for /api/walrus/access)
# Struct type used to validate active subscription ownership on Sui Testnet
WALRUS_SUBSCRIPTION_TYPE=0xYOUR_PACKAGE::subscription::SubscriptionToken

# Comma-separated Walrus object IDs returned when subscription check passes
WALRUS_OBJECT_IDS=
