{
  "name": "hackathon-patreon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "bash -c 'trap \"kill 0\" EXIT; npm run backend:dev & npm run dev'",
    "backend:dev": "npm --prefix backend run dev",
    "backend:build": "npm --prefix backend run build",
    "backend:start": "npm --prefix backend run start",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,ts,json}\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,ts,json}\" --check",
    "preview": "vite preview",
    "env:from-publish": "node scripts/sui-publish-to-env.mjs"
  },
  "dependencies": {
    "@mysten/dapp-kit": "^0.19.9",
    "@mysten/enoki": "^0.13.0",
    "@mysten/seal": "^0.9.4",
    "@mysten/sui": "^1.45.0",
    "@tanstack/react-query": "^5.90.10",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "postcss": "^8.4.31",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
