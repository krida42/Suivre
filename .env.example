# Enoki Configuration - Get these from Enoki Portal (https://enoki.mystenlabs.com)
VITE_ENOKI_PUBLIC_KEY=your_enoki_public_key_here

# Google OAuth Client ID - Get this from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Backend Configuration
VITE_BACKEND_URL=http://localhost:3001
VITE_USE_SPONSORED_TX=true
# Optional: set to true only if you want automatic decrypt/sign prefetch on app load.
VITE_PREFETCH_DECRYPT_ON_LOAD=false

# Sui Network Configuration - Get this from instructor
# Backward-compatible alias:
VITE_PACKAGE_ID=0x[INSTRUCTOR_PROVIDED_PACKAGE_ID]
# IMPORTANT: Must match exactly one Authorized redirect URI in Google Cloud Console.
# Example for local Vite:
VITE_ENOKI_REDIRECT_URL=http://localhost:5173
